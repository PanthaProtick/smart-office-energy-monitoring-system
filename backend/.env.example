# Copy this file to .env and fill in your real key.
# .env is already gitignored -- never commit real API keys.

# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_API_KEY

# Discord webhook used by app/services/discord_service.py to automatically
# post AI-enhanced alert notifications. Create one via a Discord channel's
# Integrations -> Webhooks settings. Optional -- if unset, the backend
# simply skips Discord delivery (everything else keeps working).
DISCORD_WEBHOOK_URL=YOUR_WEBHOOK_URL
