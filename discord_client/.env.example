# Copy this file to .env and fill in your real values.
# .env is already gitignored -- never commit real tokens.

# Discord bot token, from https://discord.com/developers/applications
# (Bot tab -> Reset Token). Required.
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN

# Base URL of the running FastAPI backend. Required.
BACKEND_URL=http://localhost:8000

# Optional: sync slash commands to a single guild for near-instant updates
# during development (right-click your Discord server -> Copy Server ID,
# with Developer Mode enabled). Leave blank to sync globally instead.
DISCORD_GUILD_ID=

# ---------------------------------------------------------------------------
# NOT used by this client -- documented here for convenience only.
#
# DISCORD_WEBHOOK_URL is read by the *backend* (app/services/discord_service.py)
# to automatically post AI-enhanced alert notifications. Set it in
# backend/.env, not this file.
# ---------------------------------------------------------------------------
